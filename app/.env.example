# ═══════════════════════════════════════════════════════
# AI AUTO CLIP — Environment Variables
# Salin file ini ke .env.local dan isi nilai yang sesuai
# JANGAN commit .env.local ke git!
# ═══════════════════════════════════════════════════════

# ───────────────────────────────────────
# GEMINI API KEYS (tambah sesuai jumlah akun Gmail)
# Minimal 1 key, maksimal 12 key
# ───────────────────────────────────────
GEMINI_KEY_01=""
GEMINI_KEY_02=""
GEMINI_KEY_03=""
GEMINI_KEY_04=""
GEMINI_KEY_05=""
GEMINI_KEY_06=""
GEMINI_KEY_07=""
GEMINI_KEY_08=""
GEMINI_KEY_09=""
GEMINI_KEY_10=""
GEMINI_KEY_11=""
GEMINI_KEY_12=""

# ───────────────────────────────────────
# DATABASE (dari Neon dashboard: neon.tech)
# DATABASE_URL: pooled connection (untuk runtime)
# DATABASE_URL_UNPOOLED: direct connection (untuk migrations)
# ───────────────────────────────────────
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

# ───────────────────────────────────────
# STORAGE (dari Vercel dashboard)
# ───────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ───────────────────────────────────────
# APP CONFIG
# ───────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
